{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "FlowCap",
    "version":  "1.0.0",
    "identifier":  "com.flowcap.app",
    "build":  {
                  "beforeDevCommand":  "npm run dev",
                  "devUrl":  "http://localhost:5173",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "FlowCap",
                                    "width":  1280,
                                    "height":  820,
                                    "minWidth":  960,
                                    "minHeight":  640,
                                    "decorations":  true,
                                    "visible":  true,
                                    "resizable":  true,
                                    "center":  true
                                }
                            ],
                "security":  {
                                 "csp":  null
                             },
                "trayIcon":  {
                                 "id":  "main-tray",
                                 "iconPath":  "../public/icon.png"
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  [
                                   "nsis",
                                   "msi"
                               ],
                   "icon":  [
                                "../public/icon.png",
                                "../public/icon.ico"
                            ],
                   "shortDescription":  "Beautiful screen recorder with auto-zoom and video export",
                   "longDescription":  "FlowCap is a free, open-source screen recorder for Windows. Record your screen with spring-physics auto-zoom, spotlight mode, webcam overlay, and export to MP4, WebM, or animated GIF. No subscription, no watermark, no cloud upload.",
                   "copyright":  "Copyright © 2026 Michael",
                   "category":  "Utility",
                   "windows":  {
                                   "webviewInstallMode":  {
                                                              "type":  "downloadBootstrapper"
                                                          },
                                   "nsis":  {
                                                "displayLanguageSelector":  false,
                                                "installMode":  "currentUser"
                                            }
                               }
               }
}
